// 🇮🇳 CreatorBharat SaaS Prisma Database Schema
// Database: PostgreSQL (Neon / Supabase)

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

model User {
  id                 String   @id @default(cuid())
  email              String   @unique
  phone              String?  @unique
  password           String
  role               Role     @default(CREATOR)
  isSuspended        Boolean  @default(false)
  twoFactorSecret    String?  // Encrypted TOTP secret
  twoFactorEnabled   Boolean  @default(false)
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  creator        Creator?
  brand          Brand?
  savedItems     SavedItem[]
  teamProfile    TeamMember?
  refreshTokens  RefreshToken[]
}

enum Role {
  CREATOR
  BRAND
  ADMIN
}

model Creator {
  id             String        @id @default(cuid())
  user           User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId         String        @unique
  handle         String        @unique
  name           String
  bio            String?
  photo          String?
  coverImage     String?
  city           String?
  state          String?
  niche          String[]
  platform       String[]
  followers      Int           @default(0)
  engagementRate Float         @default(0.0)
  rateMin        Int           @default(0)
  rateMax        Int           @default(0)
  isVerified     Boolean       @default(false)
  isPro          Boolean       @default(false)
  score          Int           @default(70)
  aadhaarUrl     String?
  panUrl         String?
  status         String        @default("DRAFT")
  fullStory      Json?
  socialLinks    Json?
  milestones     Json?
  services       Json?
  packages       Json?
  localHubs      Json?
  regionalDialects String[]
  localVoice     String?
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt

  applications       Application[]
  reviews            Review[]
  payments           Payment[]
  podcasts           Podcast[]
  walletTransactions WalletTransaction[]
  gallery            CreatorGallery[]
  gigs               CampaignGig[]
  achievements       Achievement[]
  communityPosts     CommunityPost[]
  postLikes          CommunityPostLike[]
  referralsMade      Referral[]          @relation("ReferrerRelation")
  referredBy         Referral?           @relation("ReferredRelation")
  missionCompletions MissionCompletion[]

  @@index([status])
  @@index([city, state])
  @@index([followers])
}

model Brand {
  id          String   @id @default(cuid())
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId      String   @unique
  companyName String
  industry    String?
  website     String?
  country     String   @default("India")
  state       String?
  city        String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  campaigns   Campaign[]
  reviews     Review[]
  payments    Payment[]
}

model Campaign {
  id          String   @id @default(cuid())
  brand       Brand    @relation(fields: [brandId], references: [id], onDelete: Cascade)
  brandId     String
  title       String
  description String
  budget      Int      @default(0)
  niche       String[]
  platform    String[]
  status      String   @default("ACTIVE") // ACTIVE, COMPLETED, PAUSED
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  applications Application[]
  gigs         CampaignGig[]
  payments     Payment[]

  @@index([status])
  @@index([budget])
}

model Application {
  id          String   @id @default(cuid())
  campaign    Campaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  campaignId  String
  creator     Creator  @relation(fields: [creatorId], references: [id], onDelete: Cascade)
  creatorId   String
  pitch       String?
  status      String   @default("PENDING") // PENDING, ACCEPTED, REJECTED
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@unique([campaignId, creatorId])
}

model Review {
  id           String   @id @default(cuid())
  creator      Creator  @relation(fields: [creatorId], references: [id], onDelete: Cascade)
  creatorId    String
  brand        Brand?   @relation(fields: [brandId], references: [id], onDelete: SetNull)
  brandId      String?
  reviewerName String
  text         String
  rating       Int      @default(5)
  createdAt    DateTime @default(now())
}

model Message {
  id        String   @id @default(cuid())
  brandId   String
  creatorId String
  text      String
  fromBrand Boolean  @default(true)
  read      Boolean  @default(false)
  createdAt DateTime @default(now())

  @@index([brandId, creatorId])
  @@index([createdAt])
}

model Blog {
  id            String    @id @default(cuid())
  slug          String    @unique
  title         String
  excerpt       String?
  body          String
  category      String
  author        String
  image         String?
  tags          String[]
  featured      Boolean   @default(false)
  published     Boolean   @default(false)
  views         Int       @default(0)
  likes         Int       @default(0)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  comments      Comment[]
}

model Comment {
  id        String    @id @default(cuid())
  blog      Blog      @relation(fields: [blogId], references: [id], onDelete: Cascade)
  blogId    String
  name      String
  email     String?
  text      String
  likes     Int       @default(0)
  parentId  String?
  createdAt DateTime  @default(now())

  parent    Comment?  @relation("Replies", fields: [parentId], references: [id])
  replies   Comment[] @relation("Replies")
}

model Payment {
  id                 String    @id @default(cuid())
  creator            Creator?  @relation(fields: [creatorId], references: [id], onDelete: SetNull)
  creatorId          String?
  brand              Brand?    @relation(fields: [brandId], references: [id], onDelete: SetNull)
  brandId            String?
  campaignId         String?
  campaign           Campaign? @relation(fields: [campaignId], references: [id], onDelete: SetNull)
  recipientCreatorId String?
  amount             Int
  currency           String    @default("INR")
  type               PayType
  status             PayStatus @default(PENDING)
  razorpayOrderId    String?
  razorpayId         String?   @unique
  createdAt          DateTime  @default(now())

  @@index([creatorId])
  @@index([brandId])
  @@index([campaignId])
}

enum PayType {
  PRO_LISTING
  CAMPAIGN_BOOST
  FEATURED_SLOT
  CAMPAIGN_ESCROW
}

enum PayStatus {
  PENDING
  PAID
  FAILED
  REFUNDED
  RELEASED
}

model Podcast {
  id          String   @id @default(cuid())
  creator     Creator  @relation(fields: [creatorId], references: [id], onDelete: Cascade)
  creatorId   String
  title       String
  description String?
  duration    String
  thumbnail   String?
  audioUrl    String?
  videoUrl    String?
  published   Boolean  @default(false)
  createdAt   DateTime @default(now())
}

model Newsletter {
  id        String   @id @default(cuid())
  email     String   @unique
  createdAt DateTime @default(now())
}

model ContactMessage {
  id        String   @id @default(cuid())
  name      String
  email     String
  subject   String?
  message   String
  read      Boolean  @default(false)
  createdAt DateTime @default(now())
}

model GalleryItem {
  id          String   @id @default(cuid())
  title       String
  description String
  category    String
  type        String
  date        String
  location    String
  thumbnail   String
  videoUrl    String?
  duration    String?
  tags        String[]
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model WalletTransaction {
  id              String            @id @default(cuid())
  creatorId       String
  creator         Creator           @relation(fields: [creatorId], references: [id], onDelete: Cascade)
  amount          Int               // Positive for earnings, negative for withdrawals
  type            TransactionType
  status          TransactionStatus @default(PENDING)
  description     String
  referenceId     String?           @unique
  createdAt       DateTime          @default(now())

  @@index([creatorId])
  @@index([createdAt])
}

enum TransactionType {
  CAMPAIGN_PAYOUT
  REFERRAL_REWARD
  BANK_WITHDRAWAL
  REFUND
}

enum TransactionStatus {
  PENDING
  SUCCESS
  FAILED
}

model DynamicPageConfig {
  id        String   @id @default(cuid())
  pageName  String   @unique
  content   Json
  updatedAt DateTime @updatedAt
}

model PlatformSettings {
  id        String   @id @default(cuid())
  key       String   @unique
  value     String   @db.Text
  updatedAt DateTime @updatedAt
}

model OtpVerification {
  id        String   @id @default(cuid())
  phone     String   @unique
  otp       String
  expiresAt DateTime
}

model PasswordReset {
  id        String   @id @default(cuid())
  token     String   @unique
  userId    String
  expiresAt DateTime
}

model CreatorGallery {
  id          String   @id @default(cuid())
  creatorId   String
  creator     Creator  @relation(fields: [creatorId], references: [id], onDelete: Cascade)
  imageUrl    String
  title       String?
  description String?
  createdAt   DateTime @default(now())
}

model CampaignGig {
  id          String         @id @default(cuid())
  campaignId  String
  campaign    Campaign       @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  creatorId   String
  creator     Creator        @relation(fields: [creatorId], references: [id], onDelete: Cascade)
  status      String         @default("ACTIVE") // ACTIVE, COMPLETED, CANCELLED
  milestones  GigMilestone[]
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt
}

model GigMilestone {
  id          String      @id @default(cuid())
  gigId       String
  gig         CampaignGig @relation(fields: [gigId], references: [id], onDelete: Cascade)
  title       String
  description String?
  status      String      @default("PENDING") // PENDING, SUBMITTED, APPROVED
  proofText   String?
  proofUrl    String?
  amount      Float       @default(0)
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt
}

// 🔔 In-App Notifications
model Notification {
  id        String   @id @default(cuid())
  userId    String
  title     String
  body      String
  type      String   @default("INFO") // INFO, SUCCESS, WARNING, PAYMENT, CAMPAIGN, VERIFICATION
  link      String?
  isRead    Boolean  @default(false)
  createdAt DateTime @default(now())

  @@index([userId])
  @@index([isRead])
}

// ⚙️ Dynamic Platform Settings (stored in DB, managed from admin panel)
model SystemSetting {
  id    String @id @default("singleton")

  // General
  siteName       String @default("CreatorBharat")
  supportEmail   String @default("support@creatorbharat.com")
  frontendUrl    String @default("http://localhost:5173")
  logoUrl        String @default("")
  footerEmail    String @default("hello@creatorbharat.com")

  // Pricing (in INR, stored as Rupees)
  proMembershipPrice   Int @default(49)
  campaignBoostPrice   Int @default(99)
  featuredSlotPrice    Int @default(199)
  platformFee          Int @default(10) // percentage

  // Feature Toggles
  enableAIAssistant   Boolean @default(true)
  enableEscrowSystem  Boolean @default(true)
  maintenanceMode     Boolean @default(false)
  enableEmail         Boolean @default(true)
  enableSMS           Boolean @default(true)

  // Razorpay
  razorpayKeyId   String @default("")
  razorpaySecret  String @default("")
  razorpayMode    String @default("test") // test | live

  // Email (Resend)
  resendApiKey String @default("")
  emailFrom    String @default("CreatorBharat <onboarding@creatorbharat.com>")

  // SMS
  smsProvider    String @default("fast2sms") // fast2sms | twilio
  fast2smsKey    String @default("")
  twilioSid      String @default("")
  twilioToken    String @default("")
  twilioPhone    String @default("")

  updatedAt DateTime @updatedAt
}

model Achievement {
  id          String   @id @default(cuid())
  creatorId   String
  creator     Creator  @relation(fields: [creatorId], references: [id], onDelete: Cascade)
  type        String   // PLAY_BUTTON_10K, PLAY_BUTTON_50K, PLAY_BUTTON_100K, etc.
  title       String
  description String?
  unlockedAt  DateTime @default(now())
  isAwarded   Boolean  @default(false)

  @@index([creatorId])
}

model Event {
  id              String   @id @default(cuid())
  title           String
  description     String
  date            DateTime
  location        String
  venue           String?
  type            String   // SUMMIT, WORKSHOP, MEETUP, ONLINE
  coverImage      String?
  registrationUrl String?
  eligibility     String?  // e.g. CB Score minimum
  isFeatured      Boolean  @default(false)
  published       Boolean  @default(false)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

model Referral {
  id           String   @id @default(cuid())
  referrerId   String   // Creator id who referred
  referrer     Creator  @relation("ReferrerRelation", fields: [referrerId], references: [id], onDelete: Cascade)
  referredId   String   @unique // Referred Creator id
  referred     Creator  @relation("ReferredRelation", fields: [referredId], references: [id], onDelete: Cascade)
  status       String   @default("PENDING") // PENDING, VERIFIED, REWARDED
  rewardAmount Int      @default(199)
  createdAt    DateTime @default(now())

  @@index([referrerId])
}

model Mission {
  id           String              @id @default(cuid())
  title        String
  description  String
  type         String              // REFER, POST_SOCIAL, COMPLETE_PROFILE, APPLY_CAMPAIGN
  reward       String              // "₹199 cashback", etc.
  rewardAmount Int                 @default(0)
  steps        Json?
  active       Boolean             @default(true)
  expiresAt    DateTime?
  createdAt    DateTime            @default(now())
  completions  MissionCompletion[]
}

model MissionCompletion {
  id          String   @id @default(cuid())
  missionId   String
  mission     Mission  @relation(fields: [missionId], references: [id], onDelete: Cascade)
  creatorId   String
  creator     Creator  @relation(fields: [creatorId], references: [id], onDelete: Cascade)
  proofUrl    String?
  status      String   @default("PENDING") // PENDING, VERIFIED, REWARDED
  createdAt   DateTime @default(now())

  @@index([missionId])
  @@index([creatorId])
}

model CommunityPost {
  id         String              @id @default(cuid())
  creatorId  String
  creator    Creator             @relation(fields: [creatorId], references: [id], onDelete: Cascade)
  content    String
  imageUrl   String?
  likesCount Int                 @default(0)
  likes      CommunityPostLike[]
  createdAt  DateTime            @default(now())

  @@index([creatorId])
}

model CommunityPostLike {
  id        String        @id @default(cuid())
  postId    String
  post      CommunityPost @relation(fields: [postId], references: [id], onDelete: Cascade)
  creatorId String
  creator   Creator       @relation(fields: [creatorId], references: [id], onDelete: Cascade)

  @@unique([postId, creatorId])
  @@index([creatorId])
}

model AmbassadorApplication {
  id        String   @id @default(cuid())
  name      String
  email     String
  phone     String
  instagram String?
  youtube   String?
  college   String?
  city      String
  pitch     String
  status    String   @default("PENDING") // PENDING, ACCEPTED, REJECTED
  createdAt DateTime @default(now())
}

model SavedItem {
  id         String   @id @default(cuid())
  userId     String
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  targetId   String   // The ID of the saved creator or saved campaign
  itemType   String   // "CREATOR" or "CAMPAIGN"
  createdAt  DateTime @default(now())

  @@unique([userId, targetId, itemType])
  @@index([userId])
}

model TeamMember {
  id        String   @id @default(cuid())
  userId    String   @unique
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  role      String   // "SUPERADMIN", "MODERATOR", "SUPPORT", "FINANCE"
  status    String   @default("ACTIVE") // "ACTIVE", "REVOKED"
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model InviteToken {
  id        String   @id @default(cuid())
  email     String   @unique
  role      String   // "SUPERADMIN", "MODERATOR", "SUPPORT", "FINANCE"
  token     String   @unique
  expiresAt DateTime
  createdAt DateTime @default(now())
}

// 🔐 JWT Refresh Tokens (revocable, 7-day expiry)
model RefreshToken {
  id        String   @id @default(cuid())
  token     String   @unique
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  expiresAt DateTime
  createdAt DateTime @default(now())

  @@index([userId])
}
