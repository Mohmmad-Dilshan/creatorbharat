{
  "framework": "vite",
  "installCommand": "cd creator-bharat-v3 && npm install",
  "buildCommand": "cd creator-bharat-v3 && npm run build",
  "outputDirectory": "creator-bharat-v3/dist",
  "rewrites": [
    {
      "source": "/c/:id",
      "destination": "/api/profile-preview?id=:id"
    },
    {
      "source": "/creator/:id",
      "destination": "/api/profile-preview?id=:id"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ]
}
